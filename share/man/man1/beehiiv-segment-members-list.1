.TH "BEEHIIV-SEGMENT-MEMBERS-LIST" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-segment-members-list - List full subscriber records for a segment


.SH SYNOPSIS
\fBbeehiiv segment-members list  [flags]\fP


.SH DESCRIPTION
List segment subscribers

.PP
List all members in a segment with full subscription data. Each member is returned as a subscription object containing complete subscriber information and their subscription details. Supports optional expansions for stats, custom fields, tags, referrals, and premium tiers. \fBUse this endpoint when you need detailed subscriber information.\fP If you only need subscriber IDs, use \fB/segments/{segmentId}/results\fR for a lighter-weight response.

.PP
API path: /publications/{publicationId}/segments/{segmentId}/members


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv segment-members list segment_123
beehiiv segments members segment_123 --query expand=stats,custom_fields
.EE


.SH SEE ALSO
\fBbeehiiv-segment-members(1)\fP
