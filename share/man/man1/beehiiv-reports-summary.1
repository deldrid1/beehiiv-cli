.nh
.TH "BEEHIIV-REPORTS-SUMMARY" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-reports-summary - Create a readable publication summary


.SH SYNOPSIS
\fBbeehiiv reports summary [flags]\fP


.SH DESCRIPTION
Build a business-friendly summary using publication stats, post rollups, recent posts, and recent engagement totals.


.SH OPTIONS
\fB--days\fP=7
	How many recent days of engagement activity to summarize

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for summary

.PP
\fB--recent-posts\fP=5
	How many recent posts to include in the summary


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv reports summary
beehiiv reports summary --days 30 --recent-posts 10
beehiiv reports summary --output json
.EE


.SH SEE ALSO
\fBbeehiiv-reports(1)\fP
