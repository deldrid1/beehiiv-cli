.nh
.TH "BEEHIIV-LOGIN" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-login - Sign in to Beehiiv


.SH SYNOPSIS
\fBbeehiiv login [flags]\fP


.SH DESCRIPTION
Sign in to Beehiiv using OAuth. Your browser opens the Beehiiv authorization
page and your credentials are saved securely in the OS keyring automatically.
No API key or client ID required.

.PP
For CI/CD or programmatic use, pass --api-key to authenticate with an API
key instead of OAuth.


.SH OPTIONS
\fB--client-id\fP=""
	Override the OAuth client ID

.PP
\fB--client-secret\fP=""
	Override the OAuth client secret

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for login

.PP
\fB--manual\fP[=false]
	Skip the local callback listener and paste the callback URL manually

.PP
\fB--no-browser\fP[=false]
	Print the authorization URL without opening a browser

.PP
\fB--redirect-uri\fP=""
	Override the OAuth redirect URI

.PP
\fB--scope\fP=[]
	Requested OAuth scope; repeat or use 'all'


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv login
beehiiv login --no-browser
beehiiv login --api-key YOUR_API_KEY
beehiiv login --api-key YOUR_API_KEY --publication-id pub_123
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP
