.TH "BEEHIIV-SUBSCRIPTION-TAGS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-subscription-tags - Create subscription tags


.SH SYNOPSIS
\fBbeehiiv subscription-tags [flags]\fP


.SH DESCRIPTION
Create tags that can be attached to subscriptions in the active publication.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for subscription-tags


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv subscription-tags create --body '{"name":"vip"}'
beehiiv tags add --body '{"name":"vip"}'
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP, \fBbeehiiv-subscription-tags-create(1)\fP
