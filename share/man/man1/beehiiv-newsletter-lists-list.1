.nh
.TH "BEEHIIV-NEWSLETTER-LISTS-LIST" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-newsletter-lists-list - List newsletter lists for the active publication


.SH SYNOPSIS
\fBbeehiiv newsletter-lists list [flags]\fP


.SH DESCRIPTION
List newsletter lists Beta OAuth Scope: newsletter_lists:read

.PP
 Newsletter Lists is currently in beta, the API is subject to change. List all newsletter lists for a publication.

.PP
API path: /publications/{publicationId}/newsletter_lists


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv newsletter-lists list
beehiiv nlists list --output table
.EE


.SH SEE ALSO
\fBbeehiiv-newsletter-lists(1)\fP
