.TH "BEEHIIV-CONDITION-SETS-GET" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-condition-sets-get - Show a condition set by ID


.SH SYNOPSIS
\fBbeehiiv condition-sets get  [flags]\fP


.SH DESCRIPTION
Get condition set OAuth Scope: condition_sets:read

.PP
Retrieve a single active dynamic content condition set for a publication. Use \fBexpand[]=stats\fR to calculate and return the active subscriber count synchronously.

.PP
API path: /publications/{publicationId}/condition_sets/{conditionSetId}


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for get

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv condition-sets get cond_123
beehiiv conditions show cond_123
.EE


