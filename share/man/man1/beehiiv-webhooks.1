.TH "BEEHIIV-WEBHOOKS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-webhooks - Manage publication webhooks


.SH SYNOPSIS
\fBbeehiiv webhooks [flags]\fP


.SH DESCRIPTION
Create, inspect, update, test, and delete Beehiiv webhooks for the active publication with clearer examples than the generated baseline.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for webhooks


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv webhooks list
beehiiv webhooks create --body @webhook.json
beehiiv webhooks ping endpoint_123
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP, \fBbeehiiv-webhooks-create(1)\fP, \fBbeehiiv-webhooks-delete(1)\fP, \fBbeehiiv-webhooks-get(1)\fP, \fBbeehiiv-webhooks-list(1)\fP, \fBbeehiiv-webhooks-test(1)\fP, \fBbeehiiv-webhooks-update(1)\fP
