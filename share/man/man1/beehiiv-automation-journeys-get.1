.TH "BEEHIIV-AUTOMATION-JOURNEYS-GET" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-automation-journeys-get - Get automation journey


.SH SYNOPSIS
\fBbeehiiv automation-journeys get   [flags]\fP


.SH DESCRIPTION
Get automation journey

.PP
Retrieve a single automation journey by ID.

.PP
API path: /publications/{publicationId}/automations/{automationId}/journeys/{automationJourneyId}


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for get

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


