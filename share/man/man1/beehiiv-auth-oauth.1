.TH "BEEHIIV-AUTH-OAUTH" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-auth-oauth - OAuth authentication for custom Beehiiv OAuth apps


.SH SYNOPSIS
\fBbeehiiv auth oauth [flags]\fP


.SH DESCRIPTION
Advanced OAuth authentication using your own Beehiiv OAuth app.

.PP
If you just want to sign in, run \fBbeehiiv login\fR instead — no client ID needed.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for oauth


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH SEE ALSO
\fBbeehiiv-auth(1)\fP, \fBbeehiiv-auth-oauth-login(1)\fP
