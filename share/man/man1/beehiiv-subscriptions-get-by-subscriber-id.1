.TH "BEEHIIV-SUBSCRIPTIONS-GET-BY-SUBSCRIBER-ID" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-subscriptions-get-by-subscriber-id - Find a subscription by subscriber ID


.SH SYNOPSIS
\fBbeehiiv subscriptions get-by-subscriber-id  [flags]\fP


.SH DESCRIPTION
Get subscription by subscriber ID

.PP
Retrieve a single subscription belonging to a specific publication via the subscriber ID.

.PP
API path: /publications/{publicationId}/subscriptions/by_subscriber_id/{subscriberId}


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for get-by-subscriber-id

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv subscriptions get-by-subscriber-id subscriber_123
beehiiv subscriptions subscriber subscriber_123 --query expand=stats,custom_fields
.EE


.SH SEE ALSO
\fBbeehiiv-subscriptions(1)\fP
