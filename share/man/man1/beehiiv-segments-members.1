.nh
.TH "BEEHIIV-SEGMENTS-MEMBERS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-segments-members - List the full subscriber records for a segment


.SH SYNOPSIS
\fBbeehiiv segments members  [flags]\fP


.SH DESCRIPTION
List full subscriber records for a specific segment, including optional expansion data.

.PP
API path: /publications/{publicationId}/segments/{segmentId}/members


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for members

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv segments members segment_123
beehiiv segments members segment_123 --query expand=stats,custom_fields
.EE


.SH SEE ALSO
\fBbeehiiv-segments(1)\fP
