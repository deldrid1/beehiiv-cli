.TH "BEEHIIV-AUTOMATION-JOURNEYS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-automation-journeys - Inspect and manage automation journeys


.SH SYNOPSIS
\fBbeehiiv automation-journeys [flags]\fP


.SH DESCRIPTION
List journeys inside an automation, inspect a specific journey, or enroll an existing subscriber when the automation has an active Add by API trigger.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for automation-journeys


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv automation-journeys list aut_123
beehiiv automation-journeys get aut_123 journey_123
beehiiv automation-journeys create aut_123 --body '{"email":"person@example.com"}'
beehiiv automations journeys aut_123
beehiiv automations enroll aut_123 --body '{"subscription_id":"sub_123"}'
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP, \fBbeehiiv-automation-journeys-create(1)\fP, \fBbeehiiv-automation-journeys-get(1)\fP, \fBbeehiiv-automation-journeys-list(1)\fP
