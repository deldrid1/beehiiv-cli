.nh
.TH "BEEHIIV-AUTOMATIONS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-automations - Inspect Beehiiv automations and related workflow activity


.SH SYNOPSIS
\fBbeehiiv automations [flags]\fP


.SH DESCRIPTION
List automation definitions, inspect a single automation with optional stats, and jump into the emails and journeys that belong to a specific automation.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for automations


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv automations list
beehiiv automations list --query expand=stats
beehiiv automations show aut_123 --query expand=stats
beehiiv automations emails aut_123
beehiiv automations journeys aut_123
beehiiv automations enroll aut_123 --body '{"email":"person@example.com"}'
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP, \fBbeehiiv-automations-emails(1)\fP, \fBbeehiiv-automations-enroll(1)\fP, \fBbeehiiv-automations-get(1)\fP, \fBbeehiiv-automations-journey(1)\fP, \fBbeehiiv-automations-journeys(1)\fP, \fBbeehiiv-automations-list(1)\fP
