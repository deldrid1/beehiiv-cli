.nh
.TH "BEEHIIV-TIERS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-tiers - Manage premium tiers


.SH SYNOPSIS
\fBbeehiiv tiers [flags]\fP


.SH DESCRIPTION
Create, inspect, update, and replace premium tiers for the active publication.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for tiers


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv tiers list
beehiiv tiers show tier_123
beehiiv tiers create --body @tier.json
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP, \fBbeehiiv-tiers-create(1)\fP, \fBbeehiiv-tiers-get(1)\fP, \fBbeehiiv-tiers-list(1)\fP, \fBbeehiiv-tiers-replace(1)\fP, \fBbeehiiv-tiers-update(1)\fP
