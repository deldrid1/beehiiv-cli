.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv subscriptions get sub_123
beehiiv subscriptions show sub_123 --query expand=stats,custom_fields
.EE


