.nh
.TH "BEEHIIV-REPORTS-EXPORT-POSTS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-reports-export-posts - Export posts to CSV


.SH SYNOPSIS
\fBbeehiiv reports export posts [flags]\fP


.SH DESCRIPTION
Export posts to CSV


.SH OPTIONS
\fB--file\fP=""
	Write the CSV to this file instead of stdout

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for posts

.PP
\fB--status\fP="all"
	Optional post status filter


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv reports export posts --file posts.csv
beehiiv reports export posts --status confirmed
.EE


.SH SEE ALSO
\fBbeehiiv-reports-export(1)\fP
