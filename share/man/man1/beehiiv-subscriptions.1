.TH "BEEHIIV-SUBSCRIPTIONS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-subscriptions - Manage subscriptions for a publication


.SH SYNOPSIS
\fBbeehiiv subscriptions [flags]\fP


.SH DESCRIPTION
Read, create, update, and remove Beehiiv subscriptions. This is one of the highest-traffic workflow groups in the CLI, so the help surface includes common lookup and mutation examples.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for subscriptions


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv subscriptions list --query limit=100 --all
beehiiv subscriptions get sub_123
beehiiv subscriptions find person@example.com
beehiiv subscriptions create --body '{"email":"person@example.com","reactivate_existing":false}'
.EE


