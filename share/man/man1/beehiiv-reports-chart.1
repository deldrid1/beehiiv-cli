.nh
.TH "BEEHIIV-REPORTS-CHART" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-reports-chart - Render an ASCII engagement chart


.SH SYNOPSIS
\fBbeehiiv reports chart [flags]\fP


.SH DESCRIPTION
Plot recent Beehiiv engagement metrics in the terminal. By default this prints a plain text chart; pass --output json for machine-readable chart data.


.SH OPTIONS
\fB--days\fP=7
	How many recent days to include

.PP
\fB--email-type\fP="all"
	Filter engagement metrics by email type: all, post, or message

.PP
\fB--granularity\fP="day"
	Chart granularity: day, week, or month

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for chart

.PP
\fB--metric\fP="total_opens"
	Metric to chart: total_opens, unique_opens, total_clicks, unique_clicks, total_verified_clicks, or unique_verified_clicks

.PP
\fB--width\fP=36
	Maximum width of the ASCII bar area


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv reports chart
beehiiv reports chart --metric unique_clicks --days 14
beehiiv reports chart --metric total_verified_clicks --granularity week
.EE


.SH SEE ALSO
\fBbeehiiv-reports(1)\fP
