.nh
.TH "BEEHIIV-AUTOMATIONS-ENROLL" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-automations-enroll - Enroll an existing subscriber into an automation


.SH SYNOPSIS
\fBbeehiiv automations enroll  [flags]\fP


.SH DESCRIPTION
Enroll an existing subscriber into an automation when that automation has an active Add by API trigger.

.PP
API path: /publications/{publicationId}/automations/{automationId}/journeys


.SH OPTIONS
\fB--body\fP=""
	Provide a request body as inline JSON, @path, or - for stdin

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for enroll

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv automations enroll aut_123 --body '{"email":"person@example.com"}'
beehiiv automations enroll aut_123 --body '{"subscription_id":"sub_123"}'
.EE


.SH SEE ALSO
\fBbeehiiv-automations(1)\fP
