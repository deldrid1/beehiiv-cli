.TH "BEEHIIV-POLL-RESPONSES-LIST" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-poll-responses-list - List poll responses OAuth Scope: polls:read


.SH SYNOPSIS
\fBbeehiiv poll-responses list  [flags]\fP


.SH DESCRIPTION
List poll responses OAuth Scope: polls:read

.PP
Retrieve all individual subscriber responses for a specific poll with cursor-based pagination. Use this endpoint for large datasets instead of the \fBexpand[]=poll_responses\fR parameter on the poll show endpoint.

.PP
API path: /publications/{publicationId}/polls/{pollId}/responses


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
