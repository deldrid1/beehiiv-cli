.nh
.TH "BEEHIIV-REPORTS" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-reports - Guided stats, charts, and CSV exports for a publication


.SH SYNOPSIS
\fBbeehiiv reports [flags]\fP


.SH DESCRIPTION
Generate friendly publication summaries, engagement charts, and spreadsheet-ready CSV exports without stitching raw Beehiiv endpoints together by hand.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for reports


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv reports summary
beehiiv reports chart --metric unique_opens --days 14
beehiiv reports export subscriptions --file subscriptions.csv
.EE


.SH SEE ALSO
\fBbeehiiv(1)\fP, \fBbeehiiv-reports-chart(1)\fP, \fBbeehiiv-reports-export(1)\fP, \fBbeehiiv-reports-summary(1)\fP
