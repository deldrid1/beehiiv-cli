.TH "BEEHIIV-BULK-SUBSCRIPTION-UPDATES-LIST" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-bulk-subscription-updates-list - List subscription updates


.SH SYNOPSIS
\fBbeehiiv bulk-subscription-updates list [flags]\fP


.SH DESCRIPTION
List subscription updates

.PP
Returns a list of Subscription Update objects for a publication.

.PP
API path: /publications/{publicationId}/bulk_subscription_updates


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


