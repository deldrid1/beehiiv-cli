.nh
.TH "BEEHIIV-AUTOMATION-JOURNEYS-LIST" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-automation-journeys-list - List journeys that occurred inside an automation


.SH SYNOPSIS
\fBbeehiiv automation-journeys list  [flags]\fP


.SH DESCRIPTION
List automation journeys

.PP
Retrieve a list of automation journeys that have occurred within a specific automation.

.PP
API path: /publications/{publicationId}/automations/{automationId}/journeys


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


.SH EXAMPLE
.EX
beehiiv automation-journeys list aut_123
beehiiv automations journeys aut_123 --all
.EE


.SH SEE ALSO
\fBbeehiiv-automation-journeys(1)\fP
