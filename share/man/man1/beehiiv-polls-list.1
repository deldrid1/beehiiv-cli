.TH "BEEHIIV-POLLS-LIST" "1" "Apr 2026" "beehiiv-cli" "Beehiiv CLI Manual"

.SH NAME
beehiiv-polls-list - List polls OAuth Scope: polls:read


.SH SYNOPSIS
\fBbeehiiv polls list [flags]\fP


.SH DESCRIPTION
List polls OAuth Scope: polls:read

.PP
Retrieve all polls belonging to a specific publication. Poll choices are always included. Use \fBexpand[]=stats\fR to include aggregate vote counts per choice.

.PP
API path: /publications/{publicationId}/polls


.SH OPTIONS
\fB--all\fP[=false]
	Fetch every page and aggregate the results

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--query\fP=[]
	Add a repeatable query parameter in key=value form


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override the Beehiiv API key

.PP
\fB--base-url\fP=""
	Override the API base URL

.PP
\fB--compact\fP[=false]
	Print compact JSON

.PP
\fB--config\fP=""
	Override the settings file location

.PP
\fB--debug\fP[=false]
	Print request URLs to stderr

.PP
\fB--output\fP=""
	Choose the output format (json, table, raw)

.PP
\fB--publication-id\fP=""
	Override the Beehiiv publication ID

.PP
\fB--rate-limit-rpm\fP=0
	Override the internal rate limit

.PP
\fB--raw\fP[=false]
	Shorthand for --output raw

.PP
\fB--table\fP[=false]
	Shorthand for --output table

.PP
\fB--timeout\fP=""
	Override the request timeout, e.g. 45s

.PP
\fB--verbose\fP[=false]
	Print request and response details to stderr


